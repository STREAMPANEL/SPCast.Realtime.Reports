msgid "Realtime Statistics"
msgstr "Statystyki w czasie rzeczywistym"

msgid "Get anonymized realtime statistics on user activities within the SPCast network. Track general trends and analyze user behavior across all radio stations in a centralized overview."
msgstr "Uzyskaj anonimowe statystyki w czasie rzeczywistym dotyczące aktywności użytkowników w sieci SPCast. Śledź ogólne trendy i analizuj zachowania użytkowników we wszystkich stacjach radiowych w scentralizowanym przeglądzie."

msgid "These are users who tuned in to a station in the network within the last 30 minutes."
msgstr "Są to użytkownicy, którzy dostroili się do stacji w sieci w ciągu ostatnich 30 minut."

msgid "These are users who tuned out of a station in the network within the last 30 minutes."
msgstr "Są to użytkownicy, którzy wyłączyli stację w sieci w ciągu ostatnich 30 minut."

msgid "Shows user countries for today, yesterday, the last 7, and the last 30 days."
msgstr "Pokazuje kraje użytkowników na dziś, wczoraj, ostatnie 7 i ostatnie 30 dni."

msgid "Shows user regions for today, yesterday, the last 7, and the last 30 days."
msgstr "Pokazuje regiony użytkowników na dziś, wczoraj, ostatnie 7 i ostatnie 30 dni."

msgid "Shows user cities for today, yesterday, the last 7, and the last 30 days."
msgstr "Pokazuje miasta użytkowników na dziś, wczoraj, ostatnie 7 i ostatnie 30 dni."

msgid "Shows user operating systems for today, yesterday, the last 7, and the last 30 days."
msgstr "Pokazuje systemy operacyjne użytkowników na dzień dzisiejszy, wczorajszy, ostatnie 7 i ostatnie 30 dni."

msgid "Shows used browsers for today, yesterday, the last 7, and the last 30 days."
msgstr "Pokazuje używane przeglądarki na dziś, wczoraj, ostatnie 7 i ostatnie 30 dni."

msgid "Shows user mountpoints for today, yesterday, the last 7, and the last 30 days."
msgstr "Pokazuje punkty montowania użytkowników na dzień dzisiejszy, wczorajszy, ostatnie 7 i ostatnie 30 dni."

msgid "Shows user activity protocols for today, yesterday, the last 7, and the last 30 days."
msgstr "Pokazuje protokoły aktywności użytkowników na dziś, wczoraj, ostatnie 7 i ostatnie 30 dni."

msgid "Shows used ports for today, yesterday, the last 7, and the last 30 days."
msgstr "Pokazuje używane porty na dziś, wczoraj, ostatnie 7 i ostatnie 30 dni."

msgid "Shows used IP versions for today, yesterday, the last 7, and the last 30 days."
msgstr "Pokazuje używane wersje IP na dziś, wczoraj, ostatnie 7 i ostatnie 30 dni."

