msgid "Realtime Statistics"
msgstr "Štatistiky v reálnom čase"

msgid "Get anonymized realtime statistics on user activities within the SPCast network. Track general trends and analyze user behavior across all radio stations in a centralized overview."
msgstr "Získajte anonymizované štatistiky v reálnom čase o aktivitách používateľov v rámci siete SPCast. Sledujte všeobecné trendy a analyzujte správanie používateľov vo všetkých rozhlasových staniciach v centralizovanom prehľade."

msgid "These are users who tuned in to a station in the network within the last 30 minutes."
msgstr "Sú to používatelia, ktorí sa naladili na stanicu v sieti za posledných 30 minút."

msgid "These are users who tuned out of a station in the network within the last 30 minutes."
msgstr "Sú to používatelia, ktorí sa za posledných 30 minút odpojili zo stanice v sieti."

msgid "Shows user countries for today, yesterday, the last 7, and the last 30 days."
msgstr "Zobrazuje používateľské krajiny pre dnešok, včerajšok, posledných 7 a posledných 30 dní."

msgid "Shows user regions for today, yesterday, the last 7, and the last 30 days."
msgstr "Zobrazuje používateľské regióny pre dnes, včera, posledných 7 a posledných 30 dní."

msgid "Shows user cities for today, yesterday, the last 7, and the last 30 days."
msgstr "Zobrazuje používateľské mestá pre dnešok, včerajšok, posledných 7 a posledných 30 dní."

msgid "Shows user operating systems for today, yesterday, the last 7, and the last 30 days."
msgstr "Zobrazuje používateľské operačné systémy pre dnes, včera, posledných 7 a posledných 30 dní."

msgid "Shows used browsers for today, yesterday, the last 7, and the last 30 days."
msgstr "Zobrazuje použité prehliadače na dnes, včera, posledných 7 a posledných 30 dní."

msgid "Shows user mountpoints for today, yesterday, the last 7, and the last 30 days."
msgstr "Zobrazuje pripojovacie body používateľa na dnes, včera, posledných 7 a posledných 30 dní."

msgid "Shows user activity protocols for today, yesterday, the last 7, and the last 30 days."
msgstr "Zobrazuje protokoly aktivity používateľa pre dnešok, včerajšok, posledných 7 a posledných 30 dní."

msgid "Shows used ports for today, yesterday, the last 7, and the last 30 days."
msgstr "Zobrazuje použité porty za dnes, včera, posledných 7 a posledných 30 dní."

msgid "Shows used IP versions for today, yesterday, the last 7, and the last 30 days."
msgstr "Zobrazuje použité verzie IP pre dnes, včera, posledných 7 a posledných 30 dní."

